# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=disney_catalog
POSTGRES_USER=disney
POSTGRES_PASSWORD=disney

# JustWatch scraper (no Disney+ subscription required)
# Source: https://www.justwatch.com/us/provider/disney-plus
JUSTWATCH_COUNTRY=US
JUSTWATCH_LANGUAGE=en
JUSTWATCH_PAGE_SIZE=100

# Scraper behavior
RATE_LIMIT_MS=500
MAX_RETRIES=3

# Optional: limit scrape for dev (0 = full catalog ~2000+ titles)
SCRAPE_LIMIT=0
